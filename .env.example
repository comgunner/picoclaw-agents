# ── LLM Provider ──────────────────────────
# Uncomment and set the API key for your provider
# OPENROUTER_API_KEY=sk-or-v1-xxx
# ZHIPU_API_KEY=xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
# CEREBRAS_API_KEY=xxx

# ── Image Generation ─────────────────────
# Ideogram API Configuration
# IDEOGRAM_API_KEY=your-ideogram-api-key
# IDEOGRAM_ENDPOINT_V3=https://api.ideogram.ai/v1/ideogram-v3/generate
# IDEOGRAM_ASPECT_RATIO=4x5
# IDEOGRAM_RENDERING_SPEED=TURBO
# IDEOGRAM_STYLE_TYPE=REALISTIC
# IDEOGRAM_NUM_IMAGES=1
# IDEOGRAM_NEGATIVE=text, watermark, signature, blurry, low quality, oversaturated
# IDEOGRAM_MODEL=V_3_TURBO

# ── Chat Channel ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx
# LINE_CHANNEL_SECRET=xxx
# LINE_CHANNEL_ACCESS_TOKEN=xxx

# ── Web Search (optional) ────────────────
# BRAVE_SEARCH_API_KEY=BSA...

# ── Timezone ──────────────────────────────
TZ=Asia/Tokyo
