{
  "agents": {
    "defaults": {
      "workspace": "~/.picoclaw/workspace_multi_model",
      "restrict_to_workspace": true,
      "max_tokens": 8192,
      "max_tool_iterations": 30
    },
    "list": [
      {
        "id": "engineering_manager",
        "name": "Engineering Manager (Team Lead)",
        "default": true,
        "model": {
          "primary": "gpt-4o"
        },
        "skills": ["fullstack_developer", "agent_team_workflow"],
        "subagents": {
          "allow_agents": [
            "backend_dev",
            "frontend_dev",
            "devops_eng",
            "qa_eng",
            "security_eng"
          ],
          "max_spawn_depth": 3,
          "max_children_per_agent": 3
        }
      },
      {
        "id": "backend_dev",
        "name": "Backend Developer",
        "model": {
          "primary": "deepseek-reasoner"
        },
        "skills": ["backend_developer"],
        "tools_override": ["read_file", "write_file", "edit_file", "exec", "web_search"],
        "subagents": {}
      },
      {
        "id": "frontend_dev",
        "name": "Frontend Developer",
        "model": {
          "primary": "claude-3-5-sonnet"
        },
        "skills": ["frontend_developer"],
        "tools_override": ["read_file", "write_file", "edit_file"],
        "subagents": {}
      },
      {
        "id": "devops_eng",
        "name": "DevOps Engineer",
        "model": {
          "primary": "deepseek-chat"
        },
        "skills": ["devops_engineer"],
        "tools_override": ["read_file", "write_file", "exec"],
        "subagents": {}
      },
      {
        "id": "qa_eng",
        "name": "QA Engineer",
        "model": {
          "primary": "claude-3-5-sonnet"
        },
        "skills": ["qa_engineer"],
        "tools_override": ["read_file", "write_file", "exec"],
        "subagents": {}
      },
      {
        "id": "security_eng",
        "name": "Security Engineer",
        "model": {
          "primary": "gpt-4o"
        },
        "skills": ["security_engineer"],
        "tools_override": ["read_file", "web_search"],
        "subagents": {}
      },
      {
        "id": "senior_developer",
        "name": "Senior Full-Stack Developer",
        "model": {
          "primary": "deepseek-reasoner"
        },
        "skills": ["backend_developer", "fullstack_developer"],
        "subagents": {
          "allow_agents": [
            "qa_eng",
            "junior_developer"
          ],
          "max_spawn_depth": 2
        }
      },
      {
        "id": "junior_developer",
        "name": "Junior Code Fixer",
        "model": {
          "primary": "deepseek-chat"
        },
        "skills": ["fullstack_developer"],
        "subagents": {}
      }
    ]
  },
  "model_list": [
    {
      "model_name": "deepseek-reasoner",
      "model": "deepseek/deepseek-reasoner",
      "api_base": "https://api.deepseek.com/v1",
      "api_key": "YOUR_DEEPSEEK_API_KEY_HERE"
    },
    {
      "model_name": "deepseek-chat",
      "model": "deepseek/deepseek-chat",
      "api_base": "https://api.deepseek.com/v1",
      "api_key": "YOUR_DEEPSEEK_API_KEY_HERE"
    },
    {
      "model_name": "gpt-4o",
      "model": "openai/gpt-4o",
      "api_key": "YOUR_OPENAI_API_KEY_HERE"
    },
    {
      "model_name": "claude-3-5-sonnet",
      "model": "anthropic/claude-3-5-sonnet-20241022",
      "api_key": "YOUR_ANTHROPIC_API_KEY_HERE"
    },
    {
      "model_name": "gemini-2.5-flash",
      "model": "gemini/gemini-2.5-flash",
      "api_key": ""
    },
    {
      "model_name": "gemini-2.5-flash-image",
      "model": "gemini/gemini-2.5-flash-image",
      "api_key": ""
    },
    {
      "model_name": "gemini-3.1-pro-high",
      "model": "antigravity/gemini-3.1-pro-high",
      "api_key": "",
      "auth_method": "oauth"
    },
    {
      "model_name": "antigravity-gemini-3-flash",
      "model": "antigravity/gemini-3-flash",
      "api_key": "",
      "auth_method": "oauth"
    },
    {
      "model_name": "gemini-2.5-pro",
      "model": "antigravity/gemini-2.5-pro",
      "api_key": "",
      "auth_method": "oauth"
    },
    {
      "model_name": "claude-sonnet-4-6",
      "model": "antigravity/claude-sonnet-4-6",
      "api_key": "",
      "auth_method": "oauth"
    },
    {
      "model_name": "claude-opus-4-6-thinking",
      "model": "antigravity/claude-opus-4-6-thinking",
      "api_key": "",
      "auth_method": "oauth"
    },
    {
      "model_name": "qwen2.5:0.5b",
      "model": "qwen2.5:0.5b",
      "api_base": "http://localhost:11434/v1",
      "api_key": "ollama"
    },
    {
      "model_name": "qwen2.5-coder:0.5b",
      "model": "qwen2.5-coder:0.5b",
      "api_base": "http://localhost:11434/v1",
      "api_key": "ollama"
    },
    {
      "model_name": "llama3.2:1b",
      "model": "llama3.2:1b",
      "api_base": "http://localhost:11434/v1",
      "api_key": "ollama"
    }
  ],
  "channels": {
    "telegram": {
      "enabled": false,
      "token": "YOUR_TELEGRAM_TOKEN",
      "allow_from": [
        "YOUR_ID"
      ]
    }
  },
  "tools": {
    "web": {
      "duckduckgo": {
        "enabled": true,
        "max_results": 5
      }
    },
    "cron": {
      "exec_timeout_minutes": 5
    },
    "exec": {
      "enable_deny_patterns": true,
      "custom_deny_patterns": []
    },
    "binance": {
      "api_key": "",
      "secret_key": ""
    },
    "social_media": {
      "facebook": {
        "default_page_id": "",
        "default_page_token": "",
        "app_id": "",
        "app_secret": "",
        "user_token": ""
      },
      "x": {
        "api_key": "",
        "api_secret": "",
        "access_token": "",
        "access_token_secret": ""
      },
      "discord": {
        "webhook_url": ""
      }
    },
    "notion": {
      "api_key": ""
    },
    "image_gen": {
      "provider": "gemini",
      "gemini_api_key": "YOUR_GEMINI_API_KEY",
      "gemini_text_model_name": "gemini-2.5-flash",
      "gemini_image_model_name": "gemini-2.5-flash-image",
      "ideogram_api_key": "",
      "ideogram_api_url": "https://api.ideogram.ai/v1/ideogram-v3/generate",
      "ideogram_aspect_ratio": "4x5",
      "ideogram_rendering_speed": "TURBO",
      "ideogram_style_type": "REALISTIC",
      "ideogram_num_images": 1,
      "ideogram_negative_prompt": "text, watermark, signature, blurry, low quality, oversaturated",
      "aspect_ratio": "4:5",
      "output_dir": "./workspace/image_gen",
      "image_script_path": "",
      "image_gen_script_path": ""
    },
    "skills": {
      "registries": {
        "clawhub": {
          "enabled": true,
          "base_url": "https://clawhub.ai",
          "search_path": "/api/v1/search",
          "skills_path": "/api/v1/skills",
          "download_path": "/api/v1/download"
        }
      },
      "max_concurrent_searches": 2,
      "search_cache": {
        "max_size": 50,
        "ttl_seconds": 300
      }
    }
  }
}
