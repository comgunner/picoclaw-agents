{
  "agents": {
    "defaults": {
      "workspace": "~/.picoclaw/workspace",
      "restrict_to_workspace": true,
      "provider": "qwen",
      "model": "qwen-flash",
      "max_tokens": 32768,
      "max_tool_iterations": 20
    },
    "list": [
      {
        "id": "project_manager",
        "name": "Project Manager",
        "default": true,
        "model": {
          "primary": "qwen-flash"
        },
        "subagents": {
          "allow_agents": [
            "senior_dev",
            "junior_fixer",
            "general_worker"
          ],
          "max_spawn_depth": 3
        }
      },
      {
        "id": "senior_dev",
        "name": "Senior Developer",
        "model": {
          "primary": "qwen3-coder-flash"
        },
        "subagents": {
          "allow_agents": [
            "junior_fixer"
          ],
          "max_spawn_depth": 2
        }
      },
      {
        "id": "junior_fixer",
        "name": "Junior Fixer",
        "model": {
          "primary": "qwen3-coder-flash"
        }
      },
      {
        "id": "general_worker",
        "name": "General Worker",
        "model": {
          "primary": "qwen-flash"
        },
        "subagents": {
          "allow_agents": []
        }
      }
    ]
  },
  "model_list": [
    {
      "model_name": "qwen-flash",
      "model": "qwen/qwen-flash-2025-07-28",
      "api_base": "https://dashscope-us.aliyuncs.com/compatible-mode/v1",
      "api_key": "YOUR_DASHSCOPE_API_KEY",
      "_comment": [
        "Method 1: In third-party tools (Chatbox, Cline, Claude Code, Dify, OpenClaw, Postman, Qwen Code)",
        "  Base URL regions:",
        "  - Singapore: https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
        "  - US (Virginia): https://dashscope-us.aliyuncs.com/compatible-mode/v1",
        "  - China (Beijing): https://dashscope.aliyuncs.com/compatible-mode/v1",
        "Method 2: Through code - set the API key as an environment variable.",
        "Warning: Never share your API key publicly to avoid security risks or financial loss."
      ]
    },
    {
      "model_name": "qwen3-coder-flash",
      "model": "qwen/qwen3-coder-flash",
      "api_base": "https://dashscope-us.aliyuncs.com/compatible-mode/v1",
      "api_key": "YOUR_DASHSCOPE_API_KEY"
    },
    {
      "model_name": "qwen-mt-plus",
      "model": "qwen/qwen-mt-plus",
      "api_base": "https://dashscope-us.aliyuncs.com/compatible-mode/v1",
      "api_key": "YOUR_DASHSCOPE_API_KEY"
    },
    {
      "model_name": "o3-mini-2025-01-31",
      "model": "openai/o3-mini-2025-01-31",
      "api_base": "https://api.openai.com/v1",
      "api_key": ""
    },
    {
      "model_name": "gemini-2.5-flash",
      "model": "gemini/gemini-2.5-flash",
      "api_key": ""
    },
    {
      "model_name": "gemini-2.5-flash-image",
      "model": "gemini/gemini-2.5-flash-image",
      "api_key": ""
    },
    {
      "model_name": "qwen2.5:0.5b",
      "model": "qwen2.5:0.5b",
      "api_base": "http://localhost:11434/v1",
      "api_key": "ollama"
    },
    {
      "model_name": "qwen2.5-coder:0.5b",
      "model": "qwen2.5-coder:0.5b",
      "api_base": "http://localhost:11434/v1",
      "api_key": "ollama"
    },
    {
      "model_name": "llama3.2:1b",
      "model": "llama3.2:1b",
      "api_base": "http://localhost:11434/v1",
      "api_key": "ollama"
    }
  ],
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "YOUR_TELEGRAM_BOT_TOKEN",
      "allow_from": [
        "YOUR_USER_ID"
      ]
    }
  },
  "tools": {
    "web": {
      "duckduckgo": {
        "enabled": true,
        "max_results": 5
      }
    },
    "cron": {
      "exec_timeout_minutes": 5
    },
    "exec": {
      "enable_deny_patterns": true,
      "custom_deny_patterns": []
    },
    "binance": {
      "api_key": "",
      "secret_key": ""
    },
    "social_media": {
      "facebook": {
        "default_page_id": "",
        "default_page_token": "",
        "app_id": "",
        "app_secret": "",
        "user_token": ""
      },
      "x": {
        "api_key": "",
        "api_secret": "",
        "access_token": "",
        "access_token_secret": ""
      },
      "discord": {
        "webhook_url": ""
      }
    },
    "notion": {
      "api_key": ""
    },
    "image_gen": {
      "provider": "gemini",
      "gemini_api_key": "",
      "gemini_text_model_name": "gemini-2.5-flash",
      "gemini_image_model_name": "gemini-2.5-flash-image",
      "ideogram_api_key": "",
      "ideogram_api_url": "https://api.ideogram.ai/v1/ideogram-v3/generate",
      "ideogram_aspect_ratio": "4x5",
      "ideogram_rendering_speed": "TURBO",
      "ideogram_style_type": "REALISTIC",
      "ideogram_num_images": 1,
      "ideogram_negative_prompt": "text, watermark, signature, blurry, low quality, oversaturated",
      "aspect_ratio": "4:5",
      "output_dir": "./workspace/image_gen",
      "image_script_path": "",
      "image_gen_script_path": ""
    },
    "skills": {
      "registries": {
        "clawhub": {
          "enabled": true,
          "base_url": "https://clawhub.ai",
          "search_path": "/api/v1/search",
          "skills_path": "/api/v1/skills",
          "download_path": "/api/v1/download"
        }
      },
      "max_concurrent_searches": 2,
      "search_cache": {
        "max_size": 50,
        "ttl_seconds": 300
      }
    }
  },
  "context_management": {
    "compact_threshold": 0.75,
    "critical_threshold": 0.9,
    "min_completion_tokens": 512,
    "preserve_messages": 15,
    "auto_compact_enabled": true
  }
}